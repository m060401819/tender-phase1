# Development example only. Production must provide explicit runtime values and must not reuse the default local DATABASE_URL.
APP_NAME=招标信息聚合平台一期
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tender_phase1
